# Server Configuration
PORT=3001
NODE_ENV=development

# Campaigns Directory
CAMPAIGNS_DIR=./campaigns

# Player Sites Directory
PLAYER_SITES_DIR=./player-sites

# Google Drive Sync (optional)
GOOGLE_DRIVE_ENABLED=false
GOOGLE_DRIVE_CREDENTIALS=

# Anthropic Claude API (for NPC generation)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# =============================================================================
# Security Settings
# =============================================================================

# GM Password — only the Game Master needs a password.
# Leave blank to disable authentication entirely.
DM_PASSWORD=

# Player Names (comma-separated, no passwords needed)
# These appear as selectable options on the login screen.
# Names must match the "player" field in character frontmatter.
# Example: PLAYERS=jon,mike,scott,kyle,alex
PLAYERS=

# Rate Limiting
# Maximum API requests per 15-minute window (default: 100)
RATE_LIMIT_MAX=100
